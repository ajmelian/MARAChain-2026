{
    "name": "ajmelian/marachain",
    "description": "MARAChain — Plataforma de intercambio seguro de documentacion con firma electronica",
    "license": "GPL-3.0-or-later",
    "type": "project",
    "homepage": "https://github.com/ajmelian/MARAChain-2026",
    "authors": [
        {
            "name": "Aythami Melian Perdomo",
            "email": "ajmelper@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/ajmelian/MARAChain-2026"
    },
    "require": {
        "php": "^8.4",
        "codeigniter4/framework": "^4.7",
        "codeigniter4/settings": "^2.3",
        "codeigniter4/shield": "^1.3",
        "stripe/stripe-php": "^21.0"
    },
    "require-dev": {
        "codeigniter/phpstan-codeigniter": "^2.1",
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
