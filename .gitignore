# ── OS files ──
.DS_Store
Thumbs.db

# ── MARAChain internal tooling ──
.opencode/*
opencode.sh

# ── Sensitive config ──
*/.env
*.local.*
.env.*

# ── Dependencies ──
wwwroot/vendor/

# ── Writable/generated ──
wwwroot/writable/cache/*
wwwroot/writable/debugbar/*
wwwroot/writable/logs/*
wwwroot/writable/session/*
wwwroot/writable/uploads/*
wwwroot/writable/db/*
wwwroot/build/*

# ── SonarQube scanner working directory ──
.scannerwork/
wwwroot/.scannerwork/

# ── IDE (local config; project-wide settings like mcp.json are tracked) ──
.idea/
.vscode/
!.vscode/mcp.json
!vscode/*.code-snippets
*.swp
*.swo

# ── Frontend templates (source only) ──
resources/frontend/alpino/original/

# ── Node (if added later) ──
node_modules/

# ── Local memory vault ──
.memory/
.mcp.json
.env.continue.local
